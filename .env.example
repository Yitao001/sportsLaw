# =============================================================
# SportsLax — 体育法律咨询智能体  环境变量配置模板
# 复制此文件为 .env 并填入真实值
# =============================================================

# ── 模型提供商选择 ─────────────────────────────────────────────
# 可选值：siliconflow | tongyi | openai | anthropic
MODEL_PROVIDER=siliconflow

# 对话模型名称（与提供商对应）
# siliconflow:  deepseek-ai/DeepSeek-V3  /  Qwen/Qwen2.5-72B-Instruct
# tongyi:       qwen-max  /  qwen-plus
# openai:       gpt-4o  /  gpt-4o-mini
# anthropic:    claude-3-5-sonnet-20241022
CHAT_MODEL_NAME=deepseek-ai/DeepSeek-V3

# 向量嵌入模型名称（与提供商对应）
# siliconflow:  BAAI/bge-m3
# tongyi:       text-embedding-v4
# openai:       text-embedding-3-small
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# ── 硅基流动（推荐，兼容 OpenAI 格式）────────────────────────
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ── 阿里云通义千问 ─────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# ── OpenAI（支持自定义 base_url，可接入代理）──────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic Claude ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── API 安全配置 ───────────────────────────────────────────────
# 留空则进入开发模式（无需 API Key 即可访问）
API_KEY=your_secure_api_key_here

# 允许的跨域来源（逗号分隔），留空则允许所有来源
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── 请求限流 ────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
